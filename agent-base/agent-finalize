#!/usr/bin/env python3
"""End-of-session stats + terminal bookkeeping for an agent run (homelab agent platform).

Two modes:
  agent-finalize --snapshot   # at entrypoint: record start time + OpenRouter usage baseline
  agent-finalize <run_log>    # after the harness: salvage-push, emit `AGENT_RUN_STATS {json}`,
                              # arm/comment/strike on GitHub, push metrics, upload transcripts

Cost is computed HERE because the pod (not the launcher) holds the OpenRouter key — usage delta over
the run = this run's $. GitHub bookkeeping (auto-merge arming, the stats PR comment, the AGENT_STRIKE
issue comment) ALSO lives here since 2026-07-09 (homelab FU-064/FU-043): the dispatcher's lifetime is
decoupled from the worker's (a coordinator pod exits ~1 min after dispatch), so anything owned by the
launcher's post-run block silently doesn't happen on that path — three strikes in one session were
posted by hand before this moved in-pod. The launcher keeps a FALLBACK copy of each step, skipped when
the stats line carries the corresponding `*_by_pod` flag. Requires issues:write on the worker token
(git-token.yaml files). Everything is best-effort: a stats/bookkeeping failure must never fail the run.
"""
import json, os, re, shutil, subprocess, sys, time, urllib.parse, urllib.request

START_EPOCH = "/tmp/agent-start-epoch"
USAGE_START = "/tmp/agent-usage-start"


def or_usage():
    """Cumulative USD usage for the current OpenRouter key. Returns None when UNKNOWN — a dead/
    expired key 401s this endpoint, and failing INTO 0.0 made exactly the runs that die on key
    problems report ~$0/negative cost (agent-runtime#12; the probe-fails-into-a-value class,
    homelab TICK-LOG rule #6). The caller must treat None as 'unknown', never as a number."""
    key = os.environ.get("OPENROUTER_API_KEY")
    if not key:
        return None
    # ADR-087: under credential injection the pod holds an opaque ref only the egress proxy can
    # resolve — so this read MUST ride the proxy (OPENROUTER_HOST) when it's set; direct-to-upstream
    # would 401 the ref and turn every injected run's cost into cost_unknown.
    base = os.environ.get("OPENROUTER_HOST") or "https://openrouter.ai"
    try:
        req = urllib.request.Request(
            base.rstrip("/") + "/api/v1/key",
            headers={"Authorization": "Bearer " + key},
        )
        with urllib.request.urlopen(req, timeout=10) as r:
            return float(json.load(r)["data"].get("usage") or 0.0)
    except Exception:
        return None


def _read_float(path):
    try:
        return float(open(path).read().strip())
    except Exception:
        return None


def claude_usage():
    """Tokens/turns for a claude-harness run — the FU-066(b) stand-in for cost_usd (subscription
    tier: ~$0 marginal, so the honest record is usage, not a fake dollar figure). Summed from the
    session jsonl under ~/.claude/projects — the pod is fresh per run, so everything there is this
    run's. `turns` counts assistant messages (≈ API calls, the same grain as goose's turn cap).
    Returns {} when no session file is found (e.g. claude died before writing one)."""
    base = os.path.expanduser("~/.claude/projects")
    tin = tout = cache_read = turns = 0
    found = False
    for root, _, names in os.walk(base):
        for name in names:
            if not name.endswith(".jsonl"):
                continue
            try:
                with open(os.path.join(root, name), errors="replace") as fh:
                    for line in fh:
                        try:
                            ev = json.loads(line)
                        except Exception:
                            continue
                        if not isinstance(ev, dict):
                            continue  # a non-dict line must not abort the rest of the file
                        usage = (ev.get("message") or {}).get("usage")
                        if ev.get("type") == "assistant" and usage:
                            found = True
                            turns += 1
                            tin += int(usage.get("input_tokens") or 0) \
                                + int(usage.get("cache_creation_input_tokens") or 0)
                            cache_read += int(usage.get("cache_read_input_tokens") or 0)
                            tout += int(usage.get("output_tokens") or 0)
            except Exception:
                continue
    if not found:
        return {}
    return {"turns": turns, "tokens_in": tin, "tokens_cache_read": cache_read, "tokens_out": tout}


def claude_cost_equiv(log_path):
    """Opportunistic API-equivalent cost: `claude -p --output-format json` ends the log with a
    result object carrying total_cost_usd. Absent (plain text output), returns None — tokens/turns
    above remain the record."""
    try:
        text = open(log_path, errors="replace").read()
    except Exception:
        return None
    val = None
    for m in re.finditer(r'"total_cost_usd"\s*:\s*([0-9.eE+-]+)', text):
        try:
            val = float(m.group(1))
        except ValueError:
            continue
    return val


def snapshot():
    open(START_EPOCH, "w").write(str(int(time.time())))
    usage = or_usage()
    open(USAGE_START, "w").write("" if usage is None else repr(usage))


def parse_outcome(log_path):
    """Pull the recipe's structured final_output JSON (last matching object) from the run log."""
    keys = ("reproduced", "ci_passed", "branch", "pr_url", "coverage_pct", "root_cause")
    found = {}
    try:
        text = open(log_path, errors="replace").read()
    except Exception:
        return found
    # The recipe emits a brace-free-inner JSON object with these keys; take the last well-formed one.
    for m in re.finditer(r'\{[^{}]*"(?:reproduced|pr_url|ci_passed)"[^{}]*\}', text):
        try:
            obj = json.loads(m.group(0))
            found = {k: obj[k] for k in keys if k in obj}
        except Exception:
            continue
    return found


def classify(log_path, stats):
    """Classify the run into (exit_status, error_class) — the FU-057 enabler.

    exit_status ∈ clean | ci-failed | no-artifact | harness-death | auth-storm | budget-403 | timeout | failed
    error_class = the dominant machine-detectable cause ('' when clean). Derived from run.log
    patterns + the run's OUTCOME (did it open a PR / pass CI). This is what makes the model-blacklist
    call possible (docs/agents/observability-and-retro.md §B1): the ledger needs to know *why* a run
    ended, not just that it cost $X and took Ys.

    Why not trust HARNESS_EXIT: measured 2026-07-09, goose exits 0 even when it storms on auth or
    dies to a `-32602` truncation (worker-r3 issue-1: 530 auth failures, no PR, exit 0). So SUCCESS
    is judged by artifact (pr_url / ci_passed), and FAILURE by the dominant log pattern — the exit
    code is only a last-resort tiebreak. Patterns are line-precise (not bare "401", which matches
    digits inside filenames/ids — a successful run logged 21 such false hits).
    """
    try:
        harness_exit = int(str(os.environ.get("HARNESS_EXIT", "")).strip() or "0")
    except ValueError:
        harness_exit = 0
    text = ""
    if log_path:
        try:
            with open(log_path, errors="replace") as fh:
                text = fh.read()
        except Exception:
            text = ""

    def n(pat):
        return len(re.findall(pat, text, re.IGNORECASE | re.MULTILINE))

    # Line-precise signatures (measured against the first oracle-fleet runs, 2026-07-09).
    # git-auth is GIT/GH-specific (a dead ~1h App token at push/PR time), distinct from the LLM-key
    # auth storm: a run whose WORK is green but whose push 401s must classify no-artifact/token-expiry,
    # not auth-storm (oracle-fleet#1 attempt 1: 49 min of green work stranded by exactly this).
    gitauth = n(r"authentication failed for 'https://github|fatal: could not read username|"
                r"bad credentials|gh: .*http 401|failed to fetch oauth token")
    auth = n(r"authentication failed|401 unauthorized|403 forbidden|invalid api key|"
             r"no auth credentials|invalid_api_key")
    forbidden = n(r"403 forbidden")
    # OpenRouter budget cap / billing 402 — the retry-into-a-wall class. Precise phrasings only, so
    # legal/statute text containing "credit"/"quota" (2–3 stray hits/run) doesn't trip it.
    budget = n(r"insufficient (credit|quota|fund)|require[sd]? more credit|payment required|"
               r"402 payment|quota exceeded|budget exceeded|out of credit|key limit exceeded")
    truncation = n(r"-32602|response may have been truncated|maximum context length|"
                   r"context_length_exceeded")
    panic = n(r"thread '.*' panicked|panicked at|fatal runtime error")
    timeout = n(r"context deadline exceeded|operation timed out|request timed out|"
                r"timeout of \d+\s*ms exceeded")

    ci_passed = stats.get("ci_passed")
    # SUCCESS requires the ARTIFACT — a PR. ci_passed alone is NOT clean: a run whose work went
    # green in-pod but never reached GitHub (dead git token, unpushed branch) used to classify
    # `clean` and poison the model-health pivot with a success that shipped nothing (oracle-fleet#1
    # attempt 1). Those runs are `no-artifact` now.
    succeeded = bool(stats.get("pr_url"))

    # Dominant failure signature (precedence: a broken key dooms the whole run, so it outranks the
    # truncation it usually ends on; ≥5 auth failures = a storm, not a transient token refresh).
    if budget:
        fail = ("budget-403", "budget-exhausted")
    elif gitauth and ci_passed is True:
        fail = ("no-artifact", "token-expiry")  # green work, dead git token at push/PR time
    elif auth >= 5:
        fail = ("auth-storm", "http-403-storm" if forbidden >= auth - forbidden else "http-401-storm")
    elif truncation:
        fail = ("harness-death", "goose-32602-truncation")
    elif panic:
        fail = ("harness-death", "goose-panic")
    elif timeout:
        fail = ("timeout", "timeout")
    else:
        fail = None

    if succeeded:
        if ci_passed is False:
            return "ci-failed", "ci-red"
        return "clean", ""
    if fail:
        return fail
    if ci_passed is True:
        return "no-artifact", "no-pr"  # green in-pod, no PR, no detectable infra cause
    if harness_exit != 0:
        return "failed", "nonzero-exit-%d" % harness_exit
    return "failed", "no-output"  # goose exited 0 but produced no PR and left no detectable error


def _fresh_gh_env():
    """Env for git/gh subprocesses with the FRESHEST git token. The mounted Secret file (rotated by
    ESO every refreshInterval) beats the env var, which is frozen at pod start — a >60-min run's env
    token is dead by the time finalize pushes (homelab FU-064b)."""
    env = dict(os.environ)
    path = os.environ.get("GIT_TOKEN_FILE", "/secrets/git/token")
    try:
        tok = open(path).read().strip()
    except Exception:
        tok = ""
    if tok:
        env["GH_TOKEN"] = tok
    return env


def salvage_push(stats):
    """FU-064a: harness-owned terminal push. If the run ends without a PR but the work branch has
    commits (and/or uncommitted state), commit + push it — a died run must leave a RESUMABLE branch,
    never zero artifact. The push-early recipe rule failed to bind on 3 runs / 2 models (homelab
    TICK-LOG 2026-07-09): this is the mechanism that replaces the exhortation. Best-effort."""
    if stats.get("pr_url"):
        return
    wd = os.environ.get("WORKDIR", "/work/repo")
    base = os.environ.get("BASE_REF", "master")
    if not os.path.isdir(os.path.join(wd, ".git")):
        return

    def git(*args, timeout=60):
        return subprocess.run(["git", "-C", wd, *args], capture_output=True, text=True,
                              timeout=timeout, env=_fresh_gh_env())

    try:
        branch = git("rev-parse", "--abbrev-ref", "HEAD").stdout.strip()
        if not branch or branch in ("HEAD", base):
            return
        if git("status", "--porcelain").stdout.strip():
            git("add", "-A")
            git("commit", "-m", "wip(salvage): uncommitted state at terminal [agent-finalize]")
        ahead = git("rev-list", "--count", "origin/%s..HEAD" % base).stdout.strip()
        if not ahead.isdigit() or int(ahead) == 0:
            return
        # --force-with-lease: the branch may exist remotely from a prior attempt of the same round.
        pushed = git("push", "--force-with-lease", "-u", "origin", branch, timeout=120)
        if pushed.returncode == 0:
            stats["salvaged_branch"] = branch
            print("salvage: pushed %s (%s commits ahead of %s)" % (branch, ahead, base), flush=True)
        else:
            print("salvage: push FAILED for %s: %s (non-fatal)"
                  % (branch, pushed.stderr.strip()[-300:]), file=sys.stderr)
    except Exception as e:
        print("salvage: non-fatal error: %s" % e, file=sys.stderr)


def _last_lines(log_path, count=15):
    try:
        with open(log_path, errors="replace") as fh:
            return "".join(fh.readlines()[-count:])
    except Exception:
        return ""


def bookkeeping(stats, log_path):
    """In-pod GitHub bookkeeping (FU-064/FU-043): with a PR — arm auto-merge (an un-armed PR is
    invisible to the ENTIRE merge path: updater, review reflex, GitHub auto-merge) + post the stats
    comment; without a PR — post the AGENT_STRIKE comment to the issue (that comment IS the strike
    store the coordinator walks the model chain by; keep the first line's format STABLE). Sets
    *_by_pod flags in stats so the launcher's fallback skips what already happened."""
    if not shutil.which("gh"):
        print("bookkeeping: gh not in image — left to the launcher fallback", file=sys.stderr)
        return
    env = _fresh_gh_env()

    def gh(*args, timeout=30):
        return subprocess.run(["gh", *args], capture_output=True, text=True, timeout=timeout, env=env)

    pr_url = stats.get("pr_url") or ""
    task = os.environ.get("AGENT_TASK") or ""
    repo_url = os.environ.get("REPO_URL") or ""
    slug = ""
    if repo_url.startswith("https://github.com/"):
        slug = repo_url[len("https://github.com/"):].removesuffix(".git")

    try:
        if pr_url:
            armed = gh("pr", "merge", pr_url, "--auto", "--squash")
            if armed.returncode == 0:
                stats["armed_by_pod"] = True
                print("bookkeeping: auto-merge armed on " + pr_url, flush=True)
            else:
                print("bookkeeping: arm FAILED: %s (launcher/reflex re-arms)"
                      % armed.stderr.strip()[-200:], file=sys.stderr)
            body = (
                "\U0001f916 **Agent run stats** (posted in-pod)\n\n"
                "| metric | value |\n|---|---|\n"
                "| model | `%s` (%s) |\n"
                "| cost | %s |\n"
                "| duration | %ss |\n"
                "| ci_passed | %s |\n"
                "| exit / error_class | `%s` / `%s` |\n"
                "| node / pod | `%s` / `%s` |\n\n"
                "\U0001f5c2 transcripts: `s3://agent-transcripts/%s/%s/`"
            ) % (
                stats.get("model", "?"), stats.get("harness", "?"),
                ("$%s" % stats["cost_usd"]) if "cost_usd" in stats
                else ("subscription — %s turns, %s in (+%s cached) / %s out tok" % (
                    stats.get("turns", "?"), stats.get("tokens_in", "?"),
                    stats.get("tokens_cache_read", 0), stats.get("tokens_out", "?"),
                )) if stats.get("subscription") else "unknown (key unreadable)",
                stats.get("duration_s", 0), stats.get("ci_passed", "?"),
                stats.get("exit_status", "?"), stats.get("error_class", "") or "clean",
                stats.get("node", "?"), stats.get("pod", "?"),
                stats.get("project", "?"), task or "adhoc",
            )
            commented = gh("pr", "comment", pr_url, "--body", body)
            if commented.returncode == 0:
                stats["stats_comment_by_pod"] = True
        elif task.startswith("issue-") and slug:
            issue = task[len("issue-"):]
            err = stats.get("error_class") or "unknown"
            if stats.get("exit_status") in ("failed", "ci-failed"):
                err = "unknown"
            strike = "AGENT_STRIKE: model=%s error_class=%s round=%s session=%s" % (
                os.environ.get("MODEL") or stats.get("model", "?"), err,
                os.environ.get("AGENT_ROUND", "1"), stats.get("pod", "?"),
            )
            salvage_note = (
                "\n\n**Resumable branch pushed:** `%s` — the next round can resume from it (C5), "
                "not restart." % stats["salvaged_branch"]
            ) if stats.get("salvaged_branch") else "\n\n(no resumable branch — nothing was committed)"
            body = "%s%s\n\n<details><summary>last 15 log lines (%s)</summary>\n\n~~~text\n%s~~~\n\n</details>\n" % (
                strike, salvage_note, stats.get("pod", "?"), _last_lines(log_path))
            posted = gh("issue", "comment", issue, "--repo", slug, "--body", body)
            if posted.returncode == 0:
                stats["strike_by_pod"] = True
                print("bookkeeping: strike posted to %s#%s" % (slug, issue), flush=True)
            else:
                print("bookkeeping: strike comment FAILED: %s (launcher fallback posts it)"
                      % posted.stderr.strip()[-200:], file=sys.stderr)
    except Exception as e:
        print("bookkeeping: non-fatal error: %s" % e, file=sys.stderr)


def push_metrics(stats, exit_status, error_class):
    """Push this run's cost/duration/outcome to the Prometheus pushgateway (FU-057 §B1) so worker
    $ reaches Prometheus — today it only rode the Loki stats line. Coordinator/reviewer cost already
    lands via A0's OTLP `claude_code_*`; this is the goose-worker equivalent (goose has no OTLP).

    Grouping key = job/role/project/issue/round (PUT replaces that group, so a re-run of the same
    issue/round overwrites rather than accumulating a stale series). model/node/harness/exit_status/
    error_class ride as metric labels → the model-health & cost dashboards pivot on them. Best-effort:
    an unreachable pushgateway (or none) must never fail the run.
    """
    url = os.environ.get(
        "AGENT_PUSHGATEWAY_URL",
        "http://prometheus-pushgateway.monitoring.svc.cluster.local:9091",
    )
    if not url:
        return
    task = os.environ.get("AGENT_TASK") or "adhoc"
    issue = task[len("issue-"):] if task.startswith("issue-") else task
    rnd = os.environ.get("AGENT_ROUND") or "1"

    def seg(v):  # URL-path-safe grouping-key segment
        return urllib.parse.quote(str(v) or "unknown", safe="")

    group = "/metrics/job/agent_run/role/worker/project/%s/issue/%s/round/%s" % (
        seg(stats.get("project")), seg(issue), seg(rnd),
    )

    def lv(v):  # Prometheus label value escaping
        return str(v).replace("\\", r"\\").replace('"', r"\"").replace("\n", r"\n")

    labels = 'model="%s",node="%s",harness="%s",exit_status="%s",error_class="%s"' % (
        lv(stats.get("model", "")), lv(stats.get("node", "")), lv(stats.get("harness", "")),
        lv(exit_status), lv(error_class),
    )
    # cost is pushed ONLY when known — pushing 0 for an unreadable key re-creates the undercount
    # agent-runtime#12 fixed (the ledger-reflex backfills unknowns from the activity API).
    cost_line = ""
    if "cost_usd" in stats:
        cost_line = "# TYPE agent_run_cost_usd gauge\nagent_run_cost_usd{%s} %s\n" % (
            labels, stats["cost_usd"])
    # Subscription (claude) runs have no cost_usd — their usage record is tokens/turns (+ the
    # API-equivalent cost when the run emitted one). Push whichever exist so the model-health
    # and cost dashboards see the claude tier at all (homelab FU-066b).
    for key, metric in (("turns", "agent_run_turns"), ("tokens_in", "agent_run_tokens_in"),
                        ("tokens_out", "agent_run_tokens_out"),
                        ("cost_usd_equiv", "agent_run_cost_usd_equiv")):
        if key in stats:
            cost_line += "# TYPE %s gauge\n%s{%s} %s\n" % (metric, metric, labels, stats[key])
    body = (
        "%s"
        "# TYPE agent_run_duration_s gauge\n"
        'agent_run_duration_s{%s} %s\n'
        "# TYPE agent_run_total gauge\n"
        'agent_run_total{%s} 1\n'
    ) % (cost_line, labels, stats.get("duration_s", 0), labels)
    try:
        req = urllib.request.Request(
            url.rstrip("/") + group, data=body.encode(), method="PUT",
            headers={"Content-Type": "text/plain"},
        )
        urllib.request.urlopen(req, timeout=10)
        print("metrics: pushed → %s%s" % (url.rstrip("/"), group), flush=True)
    except Exception as e:
        print("metrics: pushgateway push FAILED: %s (non-fatal)" % e, file=sys.stderr)


def upload_transcripts(stats, log_path):
    """Persist the run's exhaust to the agent-transcripts bucket (homelab
    docs/agents/observability-and-retro.md §A1): manifest.json + run.log + the goose session dir →
    s3://<bucket>/<project>/<task>/worker-r<round>-<ts>/. The launcher (agents/agent-session.sh)
    injects the WRITE-ONLY key + task/round as env. Loud on failure, but NEVER fails the run —
    and it runs AFTER the AGENT_RUN_STATS line, so a hung/failed upload can't cost us the stats.
    """
    import shutil
    import subprocess
    import tempfile

    key_id = os.environ.get("AGENT_TS_ACCESS_KEY_ID")
    if not key_id:
        print("transcripts: no S3 key (AGENT_TS_* env absent) — upload skipped", file=sys.stderr)
        return
    s5 = shutil.which("s5cmd")
    if not s5:
        print("transcripts: s5cmd not in image — upload skipped", file=sys.stderr)
        return

    ts = time.strftime("%Y%m%dT%H%M%SZ", time.gmtime())
    task = os.environ.get("AGENT_TASK") or "adhoc"
    rnd = os.environ.get("AGENT_ROUND") or "1"
    bucket = os.environ.get("AGENT_TS_BUCKET", "agent-transcripts")
    endpoint = os.environ.get("AGENT_TS_ENDPOINT", "http://garage.garage.svc.cluster.local:3900")
    prefix = "s3://%s/%s/%s/worker-r%s-%s" % (bucket, stats.get("project") or "unknown", task, rnd, ts)
    env = dict(
        os.environ,
        AWS_ACCESS_KEY_ID=key_id,
        AWS_SECRET_ACCESS_KEY=os.environ.get("AGENT_TS_SECRET_ACCESS_KEY", ""),
        AWS_REGION="garage",
    )

    def put(src, dst):
        try:
            subprocess.run(
                [s5, "--endpoint-url", endpoint, "cp", src, dst],
                env=env, check=True, timeout=120,
                stdout=subprocess.DEVNULL, stderr=subprocess.PIPE,
            )
            return True
        except Exception as e:
            print("transcripts: upload FAILED for %s: %s (non-fatal)" % (src, e), file=sys.stderr)
            return False

    files = []
    if log_path and os.path.exists(log_path) and put(log_path, prefix + "/run.log"):
        files.append("run.log")
    # goose's native session files (the pod is fresh per run, so everything there is this run's).
    # opencode keeps no equivalent local transcript — run.log is its record.
    sdir = os.path.expanduser("~/.local/share/goose/sessions")
    for root, _, names in os.walk(sdir):
        for n in names:
            p = os.path.join(root, n)
            rel = os.path.relpath(p, sdir)
            if put(p, "%s/goose-sessions/%s" % (prefix, rel)):
                files.append("goose-sessions/" + rel)
    # claude's session jsonl (FU-066 claude harness — same fresh-pod argument). The transcripts-sync
    # treats any *.jsonl under the run prefix as a claude session, so these land viewer-ready.
    cdir = os.path.expanduser("~/.claude/projects")
    for root, _, names in os.walk(cdir):
        for n in names:
            if not n.endswith(".jsonl"):
                continue
            p = os.path.join(root, n)
            rel = os.path.relpath(p, cdir)
            if put(p, "%s/claude-sessions/%s" % (prefix, rel)):
                files.append("claude-sessions/" + rel)

    manifest = {
        "role": "worker",
        "project": stats.get("project", ""),
        # FU-061: carry {project, issue, role, round} so the viewer sync can group by issue and
        # rewrite each session's cwd. task stays "issue-<N>" (the bucket prefix); issue is the bare N.
        "issue": task[len("issue-"):] if task.startswith("issue-") else "",
        "task": task,
        "round": int(rnd) if rnd.isdigit() else rnd,
        "model": stats.get("model", ""),
        "harness": stats.get("harness", ""),
        "session_key": os.environ.get("AGENT_SESSION_KEY", ""),
        "stats": stats,
        "exit_status": stats.get("exit_status", ""),
        "error_class": stats.get("error_class", ""),
        "harness_exit": os.environ.get("HARNESS_EXIT", ""),
        "pr_url": stats.get("pr_url", ""),
        "pod": stats.get("pod", ""),
        "grafana_query": '{pod="%s"}' % stats.get("pod", ""),
        "files": files,
    }
    with tempfile.NamedTemporaryFile("w", suffix=".json", delete=False) as f:
        json.dump(manifest, f, indent=1)
        mpath = f.name
    put(mpath, prefix + "/manifest.json")
    print("transcripts: uploaded → " + prefix, flush=True)


def finalize(log_path):
    time.sleep(6)  # let OpenRouter usage accounting settle for the last request(s)
    start_epoch = _read_float(START_EPOCH)
    stats = {
        "project": os.environ.get("PROJECT", ""),
        "pod": os.environ.get("HOSTNAME", ""),
        "node": os.environ.get("NODE_NAME", ""),
        "harness": os.environ.get("HARNESS", ""),
        "model": os.environ.get("GOOSE_MODEL") or os.environ.get("MODEL", ""),
        # KEY_HASH (operator-written into the session Secret) → the ledger-reflex can backfill a
        # cost_unknown run from the management API after the CR/pod are gone (FU-057 §ledger).
        "key_hash": os.environ.get("OPENROUTER_KEY_HASH", ""),
        "duration_s": max(0, int(time.time()) - int(start_epoch)) if start_epoch else 0,
    }
    if stats.get("harness") == "claude":
        # Subscription tier (FU-066): no OpenRouter key in play, marginal cost ~$0 — the honest
        # record is tokens/turns (claude_usage), NOT cost_unknown (that flag means "backfill me
        # from the OpenRouter activity API", which can never apply here — no key_hash).
        stats["subscription"] = True
        stats.update(claude_usage())
        equiv = claude_cost_equiv(log_path) if log_path else None
        if equiv is not None:
            stats["cost_usd_equiv"] = round(equiv, 4)
    else:
        # Cost = usage delta — but ONLY when both ends are readable. A dead key makes the end-read
        # fail; subtracting against a failed probe produced negative costs on exactly the key-death
        # runs (agent-runtime#12). Unknown is unknown: cost_unknown=true, and the ledger-reflex can
        # backfill from the OpenRouter activity API (management key) later.
        usage_start, usage_end = _read_float(USAGE_START), or_usage()
        if usage_start is not None and usage_end is not None:
            stats["cost_usd"] = max(0.0, round(usage_end - usage_start, 4))
        else:
            stats["cost_unknown"] = True
    stats.update(parse_outcome(log_path) if log_path else {})
    # FU-064a: harness-owned terminal push BEFORE classification/bookkeeping, so the salvaged branch
    # rides the stats line and the strike comment.
    salvage_push(stats)
    # FU-057: classify the run so the ledger/dashboards know *why* it ended (the model-blacklist
    # enabler). Fold exit_status+error_class into stats so they ride the AGENT_RUN_STATS line (→ the
    # launcher's PR comment + Loki) AND the manifest + pushed metrics below.
    exit_status, error_class = classify(log_path, stats)
    stats["exit_status"] = exit_status
    stats["error_class"] = error_class
    # FU-064/FU-043: in-pod GitHub bookkeeping BEFORE the stats line, so the *_by_pod flags it sets
    # ride the line and the launcher fallback knows what to skip.
    try:
        bookkeeping(stats, log_path)
    except Exception as e:
        print("bookkeeping: non-fatal error: %s" % e, file=sys.stderr)
    print("AGENT_RUN_STATS " + json.dumps(stats, separators=(",", ":")), flush=True)
    try:  # FU-057 §B1: worker $ + outcome → Prometheus (goose has no OTLP rail)
        push_metrics(stats, exit_status, error_class)
    except Exception as e:
        print("metrics: non-fatal error: %s" % e, file=sys.stderr)
    try:  # §A1 capture — deliberately after the stats line
        upload_transcripts(stats, log_path)
    except Exception as e:
        print("transcripts: non-fatal error: %s" % e, file=sys.stderr)


if __name__ == "__main__":
    try:
        if len(sys.argv) > 1 and sys.argv[1] == "--snapshot":
            snapshot()
        else:
            finalize(sys.argv[1] if len(sys.argv) > 1 else "")
    except Exception as e:  # never fail the run on stats
        print("agent-finalize: non-fatal error: %s" % e, file=sys.stderr)
